{
  "version": 2,
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist/interior-design-app",
  "framework": "angular",
  "env": [
    "EMAIL_USER",
    "EMAIL_PASSWORD",
    "RECIPIENT_EMAIL",
    "CORS_ORIGIN"
  ],
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "status": 200
    }
  ]
}
